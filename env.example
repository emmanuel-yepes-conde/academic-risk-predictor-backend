# ============================================================================
# CONFIGURACIÓN DEL BACKEND - Academic Risk Predictor
# Copiar este archivo como .env y ajustar los valores según sea necesario
# ============================================================================

# Configuración del Servidor
HOST=0.0.0.0
PORT=8000

# Configuración CORS (Orígenes permitidos)
# NOTA: CORS_ORIGINS se maneja en app/core/config.py con valor por defecto ["*"]
# Si necesitas cambiarlo, edita el código o usa variable de entorno con formato JSON:
#   export CORS_ORIGINS='["http://localhost:3000", "http://localhost:4321"]'
# No incluir CORS_ORIGINS en este archivo .env para evitar conflictos de parsing

# Rutas de Archivos ML (relativas a la raíz del proyecto)
MODEL_PATH=ml_models/modelo_logistico.joblib
SCALER_PATH=ml_models/scaler.joblib
DATASET_PATH=dataset_estudiantes_decimal.csv

# Configuración de Logging
LOG_LEVEL=info

# Umbrales de Riesgo (0-1)
UMBRAL_RIESGO_ALTO=0.7
UMBRAL_RIESGO_MEDIO=0.4

# ============================================================================
# NOTAS:
# - Renombrar este archivo a .env (eliminar el .example)
# - No subir el archivo .env al repositorio (debe estar en .gitignore)
# - Las variables de entorno tienen prioridad sobre los valores por defecto
# - En producción (Railway, Render, etc.), configurar estas variables en
#   el panel de configuración del servicio
# ============================================================================

